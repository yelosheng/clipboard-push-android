#include "resource.h"

#define IDOK 1
#define IDCANCEL 2
#define IDC_STATIC -1

// Styles
#define DS_SETFONT 0x40L
#define DS_MODALFRAME 0x80L
#define DS_FIXEDSYS 0x0008L
#define WS_POPUP 0x80000000L
#define WS_CAPTION 0x00C00000L
#define WS_SYSMENU 0x00080000L
#define ES_AUTOHSCROLL 0x0080L
#define ES_PASSWORD 0x0020L
#define ES_READONLY 0x0800L

IDD_SETTINGS_DIALOG DIALOGEX 0, 0, 300, 150
STYLE DS_SETFONT | DS_MODALFRAME | DS_FIXEDSYS | WS_POPUP | WS_CAPTION | WS_SYSMENU
CAPTION "Clipboard Man Settings"
FONT 8, "MS Shell Dlg", 400, 0, 0x1
BEGIN
    DEFPUSHBUTTON   "Save",IDOK,190,120,50,14
    PUSHBUTTON      "Cancel",IDCANCEL,245,120,50,14
    
    LTEXT           "Server URL:",IDC_STATIC,10,15,60,8
    EDITTEXT        IDC_EDIT_SERVER_URL,80,12,200,14,ES_AUTOHSCROLL
    
    LTEXT           "Room Key / ID:",IDC_STATIC,10,35,60,8
    EDITTEXT        IDC_EDIT_ROOM_KEY,80,32,200,14,ES_AUTOHSCROLL | ES_PASSWORD
    
    LTEXT           "Global Hotkey:",IDC_STATIC,10,55,60,8
    EDITTEXT        IDC_EDIT_HOTKEY,80,52,200,14,ES_AUTOHSCROLL | ES_READONLY
    
    LTEXT           "Status:",IDC_STATIC,10,80,30,8
    LTEXT           "Not Connected",IDC_STATIC_STATUS,50,80,200,8
END
